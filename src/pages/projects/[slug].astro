---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { projects } from "../../data/projects";

const visible = projects.filter((p) => !p.hidden);

export function getStaticPaths() {
  return projects
    .filter((p) => !p.hidden)
    .map((project) => ({
      params: { slug: project.slug },
      props: { project }
    }));
}

const { project } = Astro.props;
const idx = visible.findIndex((p) => p.slug === project.slug);
const previousProject = idx > 0 ? visible[idx - 1] : undefined;
const nextProject = idx >= 0 && idx < visible.length - 1 ? visible[idx + 1] : undefined;
const overview = project.abstract ?? project.details;
---

<SiteLayout
  title={`${project.title} | Shrey Niraula`}
  description={project.summary}
  path={`/projects/${project.slug}`}
>
  <section class="page-head detail">
    <div class="wrap">
      <a class="d-back" href="/projects"><i class="fa-solid fa-arrow-left"></i> Back to Projects</a>
      <h1 class="d-title">{project.title}</h1>
      <div class="d-meta">
        {project.subtitle && <span class="sub">{project.subtitle}</span>}
        {project.year && <span class="yr">{project.year}</span>}
      </div>

      {
        ((project.links && project.links.length > 0) || project.repo) && (
          <div class="d-links">
            {project.links?.map((link) => (
              <a href={link.href} target="_blank" rel="noopener">
                <i class="fa-solid fa-arrow-up-right-from-square"></i> {link.label}
              </a>
            ))}
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noopener">
                <i class="fa-brands fa-github"></i> Repository
              </a>
            )}
          </div>
        )
      }

      <div class="d-stack">{project.stack.map((s) => <span>{s}</span>)}</div>
    </div>
  </section>

  <section class="band detail" style="border-top:none;padding-top:34px;">
    <div class="wrap">
      {project.background && <p class="d-lead reveal">{project.background}</p>}

      {
        project.heroImage && (
          <div class="d-hero reveal">
            <img src={project.heroImage} alt={project.title} />
          </div>
        )
      }

      {
        project.videoUrl && (
          <div class="d-video reveal">
            <iframe
              src={project.videoUrl}
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              title={`${project.title} video`}
            />
          </div>
        )
      }

      {
        overview && (
          <div class="d-block reveal">
            <h4><span class="slash">//</span> Overview</h4>
            <p>{overview}</p>
          </div>
        )
      }

      {
        project.images && project.images.length > 0 && (
          <div class="d-block reveal">
            <h4><span class="slash">//</span> Gallery</h4>
            <div class="d-gallery">
              {project.images.map((image, index) => (
                <div class="shot">
                  <img src={image} alt={`${project.title} screenshot ${index + 1}`} loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        )
      }

      {
        project.features && project.features.length > 0 && (
          <div class="d-block reveal">
            <h4><span class="slash">//</span> Features</h4>
            {project.features.map((feature) => (
              <div class="d-feature">
                <strong>{feature.title}</strong>
                <p>{feature.description}</p>
                {feature.images && feature.images.length > 0 && (
                  <div class="images">
                    {feature.images.map((image) => (
                      <img src={image.src} alt={image.alt} title={image.title ?? image.alt} loading="lazy" />
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )
      }

      {
        (previousProject || nextProject) && (
          <div class="d-nav">
            <span>
              {previousProject && (
                <a href={previousProject.href}>
                  <i class="fa-solid fa-arrow-left"></i> Previous
                </a>
              )}
            </span>
            <span>
              {nextProject && (
                <a href={nextProject.href}>
                  Next <i class="fa-solid fa-arrow-right"></i>
                </a>
              )}
            </span>
          </div>
        )
      }
    </div>
  </section>
</SiteLayout>
