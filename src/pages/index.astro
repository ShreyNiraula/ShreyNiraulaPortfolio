          <div class="field"><label>your name <span class="star">*</span></label><input id="cfName" placeholder="Jane Doe" required /></div>
          <div class="field"><label>your email <span class="star">*</span></label><input id="cfEmail" type="email" placeholder="jane@company.com" required /></div>
          <div class="field"><label>message <span class="star">*</span></label><textarea id="cfMsg" rows="3" placeholder="Let's build something." required></textarea></div>
          <button class="btn primary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send message</button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    // 3D coverflow: active card centered/opaque, neighbors tilted back on a circle
    (function () {
      const stage = document.getElementById("pcf");
      if (!stage) return;
      const cards = Array.from(stage.querySelectorAll(".pcf-card"));
      const n = cards.length;
      if (!n) return;
      let active = 0;
      const place = () => {
        cards.forEach((card, i) => {
          let rel = i - active;
          if (rel > n / 2) rel -= n;
          if (rel < -n / 2) rel += n;
          const abs = Math.abs(rel);
          const sign = Math.sign(rel);
          let tx = 0,
            ry = 0,
            tz = 0,
            sc = 1,
            op = 1,
            z = 30;
          if (abs === 1) {
            tx = sign * 60;
            ry = -sign * 40;
            tz = -180;
            sc = 0.8;
            op = 0.4;
            z = 20;
          } else if (abs >= 2) {
            tx = sign * 82;
            ry = -sign * 48;
            tz = -320;
            sc = 0.66;
            op = 0;
            z = 10;
          }
          card.style.transform =
            "translate(-50%,-50%) translateX(" + tx + "%) translateZ(" + tz + "px) rotateY(" + ry + "deg) scale(" + sc + ")";
          card.style.opacity = op;
          card.style.zIndex = z;
          card.classList.toggle("is-center", abs === 0);
          card.setAttribute("aria-hidden", abs === 0 ? "false" : "true");
        });
      };
      place();
      const go = (dir) => {
        active = (active + dir + n) % n;
        place();
      };
      const next = document.getElementById("psNext");
      const prev = document.getElementById("psPrev");
      if (next) next.addEventListener("click", () => go(1));
      if (prev) prev.addEventListener("click", () => go(-1));
      // click a side card to bring it to center (and don't follow its links)
      cards.forEach((card, i) =>
        card.addEventListener("click", (e) => {
          if (i === active) return;
          e.preventDefault();
          active = i;
          place();
        })
      );
      // touch swipe
      let sx = null;
      stage.addEventListener("touchstart", (e) => { sx = e.touches[0].clientX; }, { passive: true });
      stage.addEventListener("touchend", (e) => {
        if (sx === null) return;
        const dx = e.changedTouches[0].clientX - sx;
        if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
        sx = null;
      }, { passive: true });
    })();

    // live GitHub contributions (only present when the section is shown)
    (async function () {
      const grid = document.getElementById("ghGrid");
      if (!grid) return;
      const note = document.getElementById("ghNote");
      const user = "ShreyNiraula";
      const colors = ["#13203a", "#0e5a4a", "#1c8f6f", "#28c98f", "#34e0a1"];
      const setText = (id, v) => {
        const el = document.getElementById(id);
        if (el) el.textContent = v;
      };
      try {
        const res = await fetch(
          "https://github-contributions-api.jogruber.de/v4/" + user + "?y=last"
        );
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json();
        const days = data.contributions || [];
        if (!days.length) throw new Error("no contribution data");
        grid.innerHTML = "";
        const pad = new Date(days[0].date + "T00:00:00").getDay();
        for (let i = 0; i < pad; i++) {
          const c = document.createElement("div");
          c.className = "gh-cell pad";
          grid.appendChild(c);
        }
        let total = 0,
          bestDay = 0,
          run = 0,
          longest = 0;
        days.forEach((d) => {
          const cell = document.createElement("div");
          cell.className = "gh-cell";
          cell.style.background = colors[d.level] || colors[0];
          cell.title =
            d.count + " contribution" + (d.count === 1 ? "" : "s") + " on " + d.date;
          grid.appendChild(cell);
          total += d.count;
          bestDay = Math.max(bestDay, d.count);
          run = d.count > 0 ? run + 1 : 0;
          longest = Math.max(longest, run);
        });
        setText("ghTotal", total.toLocaleString());
        setText("ghStreak", longest + (longest === 1 ? " day" : " days"));
        setText("ghBest", String(bestDay));
        if (note) note.remove();
      } catch (e) {
        if (note)
          note.textContent =
            "// Live GitHub contributions are unavailable right now. Try refreshing.";
      }
    })();

    // contact form opens a prefilled email
    const form = document.getElementById("contactForm");
    if (form) {
      form.addEventListener("submit", (ev) => {
        ev.preventDefault();
        const name = document.getElementById("cfName").value || "";
        const email = document.getElementById("cfEmail").value || "";
        const msg = document.getElementById("cfMsg").value || "";
        const body = encodeURIComponent(msg + "\n\n-- " + name + " (" + email + ")");
        const subject = encodeURIComponent("Portfolio inquiry from " + name);
        window.location.href =
          "mailto:nshrey53@gmail.com?subject=" + subject + "&body=" + body;
      });
    }

    // experience: click to expand/collapse bullets (smooth, measured height)
    document.querySelectorAll(".tl-toggle").forEach((btn) => {
      const item = btn.closest(".tl-item");
      if (!item) return;
      const region = item.querySelector(".tl-collapse");
      btn.addEventListener("click", () => {
        const open = item.classList.toggle("open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
        if (region) region.style.maxHeight = open ? region.scrollHeight + "px" : "40px";
      });
    });
  </script>
</SiteLayout>
