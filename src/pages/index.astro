  <!-- CONTACT -->
  <section class="band" id="contact">
    <div class="wrap">
      <div class="sec-head reveal">
        <h2>Contact</h2><span class="kick"><span class="slash">//</span> open to work and good conversations</span>
      </div>
      <div class="contact reveal">
        <div class="find">
          <a href={social.email}><span class="ic"><i class="fa-solid fa-envelope"></i></span><span class="plat">Email</span><span class="hand">nshrey53@gmail.com</span></a>
          <a href={social.github} target="_blank" rel="noopener"><span class="ic"><i class="fa-brands fa-github"></i></span><span class="plat">GitHub</span><span class="hand">/ShreyNiraula</span></a>
          <a href={social.linkedin} target="_blank" rel="noopener"><span class="ic"><i class="fa-brands fa-linkedin-in"></i></span><span class="plat">LinkedIn</span><span class="hand">/in/shrey-niraula-27947b189/</span></a>
          <a href={social.website} target="_blank" rel="noopener"><span class="ic"><i class="fa-solid fa-globe"></i></span><span class="plat">Website</span><span class="hand">shreyniraula.com.np</span></a>
          <a href={resume} target="_blank" rel="noopener"><span class="ic"><i class="fa-solid fa-id-badge"></i></span><span class="plat">Resume</span></a>
        </div>
