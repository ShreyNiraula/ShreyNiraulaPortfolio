        <div class="find">
          <a href={social.email}
            ><span class="ic"><i class="fa-solid fa-envelope"></i></span><span
              class="plat">Email</span
            ><span class="hand">nshrey53@gmail.com</span></a
          >
          <a href={social.github} target="_blank" rel="noopener"
            ><span class="ic"><i class="fa-brands fa-github"></i></span><span
