---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Shrey Niraula | Data Engineer"
  description="Data Engineer at NASA IMPACT (CSDA) building scalable data pipelines and analytics systems."
  path="/"
>
  <section id="my-about" class="home-band home-band-dark my-about">
    <div class="container">
      <div class="row my-about-intro">
        <div class="col-lg-7">
          <div class="my-intro">
            <p class="home-label">About Me</p>
            <h3>Hello, My name is Shrey Niraula.</h3>
            <p>
              I build data systems, analytics pipelines, and practical automation for teams that need reliable information flowing end to end. My background is in Electronics and Communication from Pulchowk Engineering Campus, Nepal, with a focus on data, big data, AI, and ML.
            </p>
            <p>
              I did my schooling in Japan for six years, so I am fluent in Nepali, Japanese, and English. That mix shapes how I think, learn, and communicate across different environments.
            </p>
            <p>Outside work, I watch films, movies, and anime, listen to music, and enjoy photography.</p>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="legacy-photo-wrap mt-3 mt-lg-0">
            <div class="legacy-photo-circle">
              <img src="/img/landing/IMG_14914mp.JPG" alt="Shrey Niraula" loading="lazy" />
            </div>
            <p class="legacy-photo-caption">Shrey Niraula</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="my-skills" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-4 mb-4 mb-lg-0">
          <p class="home-label home-label-dark">Skills</p>
          <h2 class="home-band-title home-band-title-dark">A sharper, more current toolset</h2>
          <p class="home-band-copy home-band-copy-dark">
            Data engineering, analytics, and application work with a focus on practical delivery.
          </p>
        </div>
        <div class="col-lg-8">
          <div class="legacy-skill-panel legacy-skill-panel-expanded">
            <div class="legacy-skills-grid legacy-skills-grid-expanded" aria-label="Skill logos">
              <div class="legacy-skill-item"><img src="/img/skills/python.png" alt="Python" loading="lazy" /><span>Python</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/spark.png" alt="Apache Spark" loading="lazy" /><span>Spark</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/mysql.png" alt="MySQL" loading="lazy" /><span>SQL</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/dremio.png" alt="Dremio" loading="lazy" /><span>Dremio</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/redshift.png" alt="Amazon Redshift" loading="lazy" /><span>Redshift</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/flask.png" alt="Flask" loading="lazy" /><span>Flask</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/react.png" alt="React" loading="lazy" /><span>React</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/git.png" alt="Git" loading="lazy" /><span>Git</span></div>
              <div class="legacy-skill-item"><img src="/img/skills/ubuntu.png" alt="Ubuntu" loading="lazy" /><span>Linux</span></div>
            </div>
            <div class="legacy-skill-tags">
              <span>Airflow</span>
              <span>ETL / ELT</span>
              <span>Data Modeling</span>
              <span>Big Data</span>
              <span>AWS</span>
              <span>Analytics</span>
              <span>Automation</span>
              <span>APIs</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="my-projects" class="home-band home-band-dark">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 order-lg-1">
          <p class="home-label">Projects</p>
          <h2 class="home-band-title">Selected engineering projects</h2>
          <p class="home-band-copy">
            Visual SLAM, traffic systems, assistive concepts, and applied data projects with details on implementation.
          </p>
        </div>
        <div class="col-lg-5 order-lg-2 text-lg-right mt-4 mt-lg-0">
          <a class="home-band-link" href="/projects">Go to Projects</a>
        </div>
      </div>
    </div>
  </section>

  <section id="my-experience" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-5 order-lg-2 text-lg-right mb-4 mb-lg-0">
          <a class="home-band-link home-band-link-dark" href="/experience">Go to Work Experience</a>
        </div>
        <div class="col-lg-7 order-lg-1">
          <p class="home-label home-label-dark">Work</p>
          <h2 class="home-band-title home-band-title-dark">Timeline of roles and impact</h2>
          <p class="home-band-copy home-band-copy-dark">
            A focused timeline of data engineering work, systems improvements, and production delivery.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="my-connect" class="home-band home-band-dark">
    <div class="container text-center">
      <p class="home-label">Let us connect</p>
      <h2 class="home-band-title">Reach out if you want to talk data, automation, or ideas</h2>
      <div class="home-connect-links">
        <a href="mailto:nshrey53@gmail.com">Email</a>
        <a href="https://www.linkedin.com/in/shrey-niraula-27947b189/">LinkedIn</a>
        <a href="https://github.com/ShreyNiraula">GitHub</a>
      </div>
    </div>
  </section>

  <section id="my-participations" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 order-lg-1">
          <p class="home-label home-label-dark">Participations</p>
          <h2 class="home-band-title home-band-title-dark">Hackathons, programs, and community work</h2>
          <p class="home-band-copy home-band-copy-dark">
            A selection of participation certificates and event-based learning experiences.
          </p>
        </div>
        <div class="col-lg-5 order-lg-2 text-lg-right mt-4 mt-lg-0">
          <a class="home-band-link home-band-link-dark" href="/participations">Go to Participations</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>