---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Shrey Niraula | Data Engineer"
  description="Data Engineer at NASA IMPACT (CSDA) building scalable data pipelines and analytics systems."
  path="/"
>
  <section id="my-about" class="home-band home-band-dark my-about">
    <div class="container">
      <div class="row my-about-intro">
        <div class="col-lg-7">
          <div class="my-intro">
            <p class="home-label">About Me</p>
            <h3>Hello, My name is Shrey Niraula.</h3>
            <p>
              I am Data Engineer with 4+ years of experience specialized in scalable
              Lakehouse architectures and Agentic AI frameworks. Proven ability
              to bridge the gap between Big Data infrastructure and LLM-driven
              automation, including developing autonomous cloud optimization
              agents and high-performance ETL pipelines.
            </p>
            <p>
              I did my schooling in Japan for six years, and I am fluent in
              Nepali, Japanese, and English. That cross-cultural background
              shapes how I collaborate, learn quickly, and communicate across
              diverse teams.
            </p>
            <p>
              Outside work, I watch films, movies, and anime, listen to music,
              and enjoy photography.
            </p>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="legacy-photo-wrap mt-3 mt-lg-0">
            <div class="legacy-photo-circle">
              <img
                src="/img/landing/IMG_14914mp.JPG"
                alt="Shrey Niraula"
                loading="lazy"
              />
            </div>
            <p class="legacy-photo-caption">Shrey Niraula</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="my-skills" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 mb-4 mb-lg-0">
          <div class="skills-visual-wrap" aria-label="Skill logos">
            <div class="skills-visual-track">
              <img src="/img/skills/python.png" alt="Python" loading="lazy" />
              <img
                src="/img/skills/spark.png"
                alt="Apache Spark"
                loading="lazy"
              />
              <img src="/img/skills/mysql.png" alt="MySQL" loading="lazy" />
              <img src="/img/skills/dremio.png" alt="Dremio" loading="lazy" />
              <img
                src="/img/skills/redshift.png"
                alt="Amazon Redshift"
                loading="lazy"
              />
              <img src="/img/skills/flask.png" alt="Flask" loading="lazy" />
              <img src="/img/skills/react.png" alt="React" loading="lazy" />
              <img src="/img/skills/git.png" alt="Git" loading="lazy" />
              <img src="/img/skills/ubuntu.png" alt="Ubuntu" loading="lazy" />
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <p class="home-label home-label-dark">Skills</p>
          <h2 class="home-band-title home-band-title-dark">
            Scalable data and AI engineering toolkit
          </h2>
          <p class="home-band-copy home-band-copy-dark">
            End-to-end experience across data platforms, pipeline engineering,
            AI-powered automation, and reliable cloud delivery.
          </p>
          <div class="legacy-skill-tags skills-tag-cloud">
            <span>Python</span>
            <span>Apache Spark</span>
            <span>SQL</span>
            <span>Dremio</span>
            <span>Redshift</span>
            <span>Flask</span>
            <span>React</span>
            <span>Git</span>
            <span>Linux</span>
            <span>Airflow</span>
            <span>ETL / ELT</span>
            <span>Data Modeling</span>
            <span>Big Data</span>
            <span>AWS</span>
            <span>Agentic AI</span>
            <span>Automation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="my-projects" class="home-band home-band-dark">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 order-lg-1">
          <p class="home-label">Projects</p>
          <h2 class="home-band-title">Selected engineering projects</h2>
          <p class="home-band-copy">
            Visual SLAM, traffic systems, assistive concepts, and applied data
            projects with details on implementation.
          </p>
        </div>
        <div class="col-lg-5 order-lg-2 text-lg-right mt-4 mt-lg-0">
          <a class="home-band-link" href="/projects">Go to Projects</a>
        </div>
      </div>
    </div>
  </section>

  <section id="my-experience" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-5 order-lg-2 text-lg-right mb-4 mb-lg-0">
          <a class="home-band-link home-band-link-dark" href="/experience"
            >Go to Work Experience</a
          >
        </div>
        <div class="col-lg-7 order-lg-1">
          <p class="home-label home-label-dark">Work</p>
          <h2 class="home-band-title home-band-title-dark">
            Timeline of roles and impact
          </h2>
          <p class="home-band-copy home-band-copy-dark">
            A focused timeline of data engineering work, systems improvements,
            and production delivery.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="my-connect" class="home-band home-band-dark">
    <div class="container text-center">
      <p class="home-label">Let us connect</p>
      <h2 class="home-band-title">
        Reach out if you want to talk data, automation, or ideas
      </h2>
      <div class="home-connect-links">
        <a href="mailto:nshrey53@gmail.com">Email</a>
        <a href="https://www.linkedin.com/in/shrey-niraula-27947b189/"
          >LinkedIn</a
        >
        <a href="https://github.com/ShreyNiraula">GitHub</a>
      </div>
    </div>
  </section>

  <section id="my-participations" class="home-band home-band-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 order-lg-1">
          <p class="home-label home-label-dark">Participations</p>
          <h2 class="home-band-title home-band-title-dark">
            Hackathons, programs, and community work
          </h2>
          <p class="home-band-copy home-band-copy-dark">
            A selection of participation certificates and event-based learning
            experiences.
          </p>
        </div>
        <div class="col-lg-5 order-lg-2 text-lg-right mt-4 mt-lg-0">
          <a class="home-band-link home-band-link-dark" href="/participations"
            >Go to Participations</a
          >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
