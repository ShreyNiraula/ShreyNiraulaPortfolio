            <div class="gh-top">
              <div class="t"><span class="live"></span> Contributions</div>
              <a class="h" href={social.github} target="_blank" rel="noopener">@ShreyNiraula · last 12 months</a>
            </div>
            <div class="gh-grid" id="ghGrid"></div>
            <div class="gh-legend">
              Less
              <span class="sw" style="background:#13203a"></span>
              <span class="sw" style="background:#0e5a4a"></span>
              <span class="sw" style="background:#1c8f6f"></span>
              <span class="sw" style="background:#28c98f"></span>
              <span class="sw" style="background:#34e0a1"></span>
              More
            </div>
            <div class="gh-stats">
              <div class="s"><div class="n" id="ghTotal">-</div><div class="l">Contributions</div></div>
              <div class="s"><div class="n" id="ghStreak">-</div><div class="l">Longest streak</div></div>
              <div class="s"><div class="n" id="ghBest">-</div><div class="l">Best day</div></div>
            </div>
