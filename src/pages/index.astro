---
// Homepage built on the Shrey Niraula design system (v2 navy direction).
// Section content is data-driven (see src/data/*); this file composes the page.
import SiteLayout from "../layouts/SiteLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { projects, type Project } from "../data/projects";
import { site, social, heroStats } from "../data/site";
import { experience } from "../data/experience";
import { skillCats } from "../data/skills";
import { participations } from "../data/participations";
import { education } from "../data/education";
import { certifications } from "../data/certifications";
import { awards } from "../data/awards";

const { title, description, resume } = site;

// Toggle optional sections (kept in code, not rendered).
const showContributions = false;
const showAwards = false;

// ---- Project showcase (glassy side-scroller) ----
type Slide = {
  badge: string;
  year: string;
  title: string;
  blurb: string;
  stack: string[];
  href: string;
  repo: string;
  live: string;
  img?: string;
  code?: string;
};

const liveOf = (p: Project): string =>
  p.links?.find((l) => /site|website|live|demo/i.test(l.label))?.href || "";

// Short display title + badge per project for the carousel cards.
const cardMeta: Record<string, { title: string; badge: string }> = {
  "agentic-ai": {
    title: "Self-Hosted Agentic LLM Framework",
    badge: "MS Thesis",
  },
  "major-project": {
    title: "Visual SLAM in Dynamic Scenes",
    badge: "Final Year",
  },
  plf: { title: "Precision Livestock Farming", badge: "Locus Winner" },
  "minor-project": { title: "Traffic Management & Analysis", badge: "" },
  "abu-robocon": { title: "ABU Robocon 2019 Simulator", badge: "" },
};

const showcase: Slide[] = projects
  .filter((p) => !p.hidden)
  .map((p): Slide => {
    const m = cardMeta[p.slug] || { title: p.title, badge: "" };
    return {
      badge: m.badge,
      year: p.year ?? "",
      title: m.title,
      blurb: p.summary || p.details || "",
      img: p.cardImage ?? p.heroImage ?? p.images?.[0],
      stack: p.stack,
      href: p.href,
      repo: p.repo || "",
      live: liveOf(p),
    };
  });

---

<SiteLayout title={title} description={description} path="/">
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <h1 class="big">
        <span class="fill">DATA</span><br /><span class="ghost">ENGINEER</span>
      </h1>
      <p class="lede">
        <b>AI, Data and Cloud enthusiast</b> building large-scale data pipelines and
        agentic AI systems. Years of data engineering experience in Marketing & Business
        and Satellite data.
      </p>
      <div class="cta-row">
        <a class="btn primary" href={resume} target="_blank" rel="noopener">
          <i class="fa-solid fa-id-badge"></i> Resume
        </a>
        <a class="btn ghost" href="#contact">Get in touch</a>
      </div>
      <div class="hero-stats">
        {
          heroStats.map((s) => (
            <div class="stat">
              <>
                <div class="n">{s.n}</div>
                <div class="l">{s.l}</div>
              </>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="band" id="about">
    <div class="wrap">
      <SectionHeading title="About Me" kicker="who I am" />
      <div class="about reveal">
        <div class="pic">
          <img src="/img/landing/me.png" alt="Shrey Niraula" />
        </div>
        <div>
          <div
            class="greet-line about-greet"
            aria-label="Hello in English, Japanese and Nepali"
          >
            <span class="greet" id="greet"></span><span class="caret"></span>
          </div>
          <p>
            I am <b>Shrey Niraula</b>, a data engineer and computer science
            graduate. Growing up in <b>Japan</b>, I spent countless hours around
            games and computers, which sparked a curiosity about how software
            works and eventually inspired me to start building things of my own.
          </p>
          <p>
            That curiosity guided me through Electronics Engineering and into a
            career centered on data, software, and AI. Today, I work at the
            intersection of <b>data engineering and agentic systems</b>,
            exploring how intelligent applications can combine reliable data
            foundations with autonomous reasoning and decision-making.
          </p>
          <p>
            Having spent part of my childhood in Japan, I still enjoy keeping up
            with the language and culture. Outside of work, you will usually
            find me watching films and anime, listening to music, or diving into
            whatever new curiosity has captured my attention.
          </p>
          <div class="langs">
            <span class="lang">Nepali (native)</span>
            <span class="lang">Japanese (fluent)</span>
            <span class="lang">English (fluent)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="band" id="skills">
    <div class="wrap">
      <SectionHeading title="Skills" kicker="my stack" />
      <div class="stack-list">
        {
          skillCats.map((c) => (
            <div class="stack-row reveal">
              <div class="stack-cat">{c.name}</div>
              <div class="stack-items">
                {c.chips.map((ch) => (
                  <div class="sk">
                    {ch.img ? (
                      <img
                        class={ch.white ? "sk-logo on-white" : "sk-logo"}
                        src={ch.img}
                        alt=""
                      />
                    ) : ch.gen ? (
                      <span class="sk-dot" />
                    ) : (
                      <i class={ch.white ? ch.i + " on-white" : ch.i} />
                    )}
                    <span class="sk-name">{ch.t}</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="band" id="xp">
    <div class="wrap">
      <SectionHeading title="Experience" kicker="where I have worked" />
      <div class="tl reveal">
        {
          experience.map((e) => (
            <div class="tl-item">
              <div class="tl-card">
                <div class="tl-when">
                  <span>{e.when}</span>
                  {e.badge && <span class="badge">{e.badge}</span>}
                </div>
                <div class="tl-headrow">
                  <h3>{e.role}</h3>
                  <span class="tl-loc">
                    <i class="fa-solid fa-location-dot" /> {e.location}
                  </span>
                </div>
                <div class="co">{e.company}</div>
                <div class="tl-collapse">
                  <ul class="tl-list">
                    {e.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                  <div class="stack">
                    {e.stack.map((s) => (
                      <span>{s}</span>
                    ))}
                  </div>
                </div>
                <button class="tl-toggle" type="button" aria-expanded="false">
                  <span class="more-label">Show more</span>
                  <span class="less-label">Show less</span>
                  <i class="fa-solid fa-chevron-down" />
                </button>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="band" id="education">
    <div class="wrap">
      <SectionHeading title="Education" kicker="where I studied" />
      <div class="edu-clean reveal">
        {
          education.map((e) => (
            <div class="edu-row">
              <div class="edu-side">
                <span class="edu-score">{e.score}</span>
              </div>
              <div class="edu-main">
                <div class="edu-headrow">
                  <h3>{e.school}</h3>
                  <div class="edu-meta">
                    <span class="edu-when">{e.when}</span>
                    <span class="edu-loc">
                      <i class="fa-solid fa-location-dot" /> {e.location}
                    </span>
                  </div>
                </div>
                <div class="edu-deg">{e.degree}</div>
                <p class="edu-hl">{e.highlight}</p>
                <div class="edu-subjects">
                  {e.subjects.map((s) => (
                    <span>{s}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PROJECTS (glassy side-scroller) -->
  <section class="band" id="projects">
    <div class="wrap">
      <SectionHeading title="Projects" kicker="selected work" />
      <div class="pscroll reveal" id="pscroll">
      {
        showcase.map((p, i) => (
          <article class={p.img ? "pcf-card" : "pcf-card no-media"} data-i={i}>
            {p.img && (
              <div class="ps-media">
                <img src={p.img} alt={p.title} loading="lazy" />
              </div>
            )}
            <div class="ps-body">
              <div class="ps-head">
                <div class="ps-count">
                  <b>{String(i + 1).padStart(2, "0")}</b> /{" "}
                  {String(showcase.length).padStart(2, "0")}
                </div>
                <div class="ps-top">
                  {p.badge && <span class="badge">{p.badge}</span>}
                  <span class="ps-yr">{p.year}</span>
                </div>
              </div>
              <h3>{p.title}</h3>
              <p>{p.blurb}</p>
              <div class="ps-stack">
                {p.stack.map((s) => (
                  <span>{s}</span>
                ))}
              </div>
              <div class="ps-links">
                <a class="ps-link" href={p.href}>
                  <i class="fa-solid fa-arrow-right" /> Details
                </a>
                {p.repo && (
                  <a
                    class="ps-link"
                    href={p.repo}
                    target="_blank"
                    rel="noopener"
                  >
                    <i class="fa-brands fa-github" /> Source
                  </a>
                )}
                {p.live && (
                  <a
                    class="ps-link"
                    href={p.live}
                    target="_blank"
                    rel="noopener"
                  >
                    <i class="fa-solid fa-arrow-up-right-from-square" /> Live
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
      </div>
      <div class="pshow-nav reveal">
        <div class="ps-arrows">
          <button class="ps-chevron left" id="psPrev" aria-label="Previous projects"></button>
          <button class="ps-chevron right" id="psNext" aria-label="Next projects"></button>
        </div>
        <a class="more-btn" href="/projects">All projects <span class="a">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- PARTICIPATIONS -->
  <section class="band" id="participations">
    <div class="wrap">
      <SectionHeading title="Participations" kicker="hackathons & programs" />
      <div class="parts embed reveal">
        {
          participations.map((p) => (
            <div class="part">
              <div class="part-top">
                <span class="badge">{p.badge}</span>
                <span class="part-yr">{p.year}</span>
              </div>
              <h3>{p.title}</h3>
              <div class="part-ev">{p.event}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- AWARDS (hidden via showAwards flag) -->
  {
    showAwards && (
      <section class="band" id="awards">
        <div class="wrap">
          <SectionHeading title="Awards" kicker="recognition" />
          <div class="parts embed reveal">
            {awards.map((a) => (
              <div class="part">
                <div class="part-top">
                  <span class="badge">Award</span>
                  <span class="part-yr">{a.year}</span>
                </div>
                <h3>{a.title}</h3>
                <p class="part-desc">{a.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CERTIFICATIONS -->
  <section class="band" id="certifications">
    <div class="wrap">
      <SectionHeading title="Certifications" kicker="courses I completed" />
      <div class="parts embed reveal">
        {
          certifications.map((c) => (
            <div class="part cert">
              <div class="part-top">
                <span class="badge">{c.provider}</span>
                <span class="part-yr">{c.year}</span>
              </div>
              <h3>{c.title}</h3>
              {c.courses && (
                <div class="cert-courses">
                  {c.courses.map((co) =>
                    co.link ? (
                      <a href={co.link} target="_blank" rel="noopener">
                        {co.t}
                      </a>
                    ) : (
                      <span>{co.t}</span>
                    ),
                  )}
                </div>
              )}
              {c.link && (
                <a
                  class="cert-verify"
                  href={c.link}
                  target="_blank"
                  rel="noopener"
                >
                  Verify <i class="fa-solid fa-arrow-up-right-from-square" />
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    showContributions && (
      <section class="band" id="github">
        <div class="wrap">
          <div class="sec-head reveal">
            <>
              <h2>Contributions</h2>
              <span class="kick">
                <span class="slash">//</span> github activity
              </span>
            </>
          </div>
          <div class="gh-wrap reveal">
            <div class="gh-top">
              <div class="t">
                <span class="live" /> Contributions
              </div>
              <a class="h" href={social.github} target="_blank" rel="noopener">
                @ShreyNiraula · last 12 months
              </a>
            </div>
            <div class="gh-grid" id="ghGrid" />
            <div class="gh-legend">
              Less
              <span class="sw" style="background:#13203a" />
              <span class="sw" style="background:#0e5a4a" />
              <span class="sw" style="background:#1c8f6f" />
              <span class="sw" style="background:#28c98f" />
              <span class="sw" style="background:#34e0a1" />
              More
            </div>
            <div class="gh-stats">
              <div class="s">
                <>
                  <div class="n" id="ghTotal">
                    -
                  </div>
                  <div class="l">Contributions</div>
                </>
              </div>
              <div class="s">
                <>
                  <div class="n" id="ghStreak">
                    -
                  </div>
                  <div class="l">Longest streak</div>
                </>
              </div>
              <div class="s">
                <>
                  <div class="n" id="ghBest">
                    -
                  </div>
                  <div class="l">Best day</div>
                </>
              </div>
            </div>
            <p class="gh-note" id="ghNote">
              // Loading live contributions from GitHub…
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- CONTACT -->
  <section class="band" id="contact">
    <div class="wrap">
      <SectionHeading title="Contacts" kicker="open to work and good conversations" />
      <div class="contact reveal">
        <div class="find">
          <a href={social.email}
            ><span class="ic"><i class="fa-solid fa-envelope"></i></span><span
              class="plat">Email</span
            ><span class="hand">nshrey53@gmail.com</span></a
          >
          <a href={social.github} target="_blank" rel="noopener"
            ><span class="ic"><i class="fa-brands fa-github"></i></span><span
              class="plat">GitHub</span
            ><span class="hand">/ShreyNiraula</span></a
          >
          <a href={social.linkedin} target="_blank" rel="noopener"
            ><span class="ic"><i class="fa-brands fa-linkedin-in"></i></span
            ><span class="plat">LinkedIn</span><span class="hand"
              >/in/shrey-niraula-27947b189/</span
            ></a
          >
          <a href={social.website} target="_blank" rel="noopener"
            ><span class="ic"><i class="fa-solid fa-globe"></i></span><span
              class="plat">Website</span
            ><span class="hand">shreyniraula.com.np</span></a
          >
          <a href={resume} target="_blank" rel="noopener"
            ><span class="ic"><i class="fa-solid fa-id-badge"></i></span><span
              class="plat">Resume</span
            ></a
          >
        </div>
        <form class="form" id="contactForm">
          <div class="field">
            <label>your name <span class="star">*</span></label><input
              id="cfName"
              placeholder="Jane Doe"
              required
            />
          </div>
          <div class="field">
            <label>your email <span class="star">*</span></label><input
              id="cfEmail"
              type="email"
              placeholder="jane@company.com"
              required
            />
          </div>
          <div class="field">
            <label>message <span class="star">*</span></label><textarea
              id="cfMsg"
              rows="3"
              placeholder="Let's build something."
              required></textarea>
          </div>
          <button class="btn primary" type="submit"
            ><i class="fa-solid fa-paper-plane"></i> Send message</button
          >
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    // hero greeting typewriter: cycles Hello / Japanese / Nepali
    (function () {
      const el = document.getElementById("greet");
      if (!el) return;
      const phrases = ["Hello", "ハロー", "नमस्ते"];
      let pi = 0,
        ci = 0,
        deleting = false;
      const tick = () => {
        const w = phrases[pi];
        if (!deleting) {
          ci++;
          el.textContent = w.slice(0, ci);
          if (ci >= w.length) {
            deleting = true;
            return setTimeout(tick, 1500);
          }
          return setTimeout(tick, 150);
        }
        ci--;
        el.textContent = w.slice(0, ci);
        if (ci <= 0) {
          deleting = false;
          pi = (pi + 1) % phrases.length;
          return setTimeout(tick, 350);
        }
        return setTimeout(tick, 75);
      };
      tick();
    })();

    // projects: infinite looping scroll (cards wrap continuously, 05 -> 01 -> 02 ...)
    (function () {
      const sc = document.getElementById("pscroll");
      if (!sc) return;
      const originals = Array.from(sc.children);
      const n = originals.length;
      if (n < 3) return;
      // clone one full set before and after so the row can scroll forever
      [...originals].reverse().forEach((c) => sc.insertBefore(c.cloneNode(true), sc.firstChild));
      originals.forEach((c) => sc.appendChild(c.cloneNode(true)));
      const setW = () => sc.children[n].offsetLeft - sc.children[0].offsetLeft;
      const stepW = () => originals[0].getBoundingClientRect().width + 22;
      // start on the middle (real) set
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          sc.scrollLeft = setW();
        }),
      );
      // recenter seamlessly after manual scrolling settles (identical content, no visible jump)
      let t;
      sc.addEventListener(
        "scroll",
        () => {
          clearTimeout(t);
          t = setTimeout(() => {
            const w = setW();
            if (sc.scrollLeft <= w * 0.5) sc.scrollLeft += w;
            else if (sc.scrollLeft >= w * 1.5) sc.scrollLeft -= w;
          }, 150);
        },
        { passive: true },
      );
      const go = (dir) => {
        const w = setW();
        const s = stepW();
        // pre-emptively recenter so the smooth scroll never runs into a boundary
        if (dir > 0 && sc.scrollLeft + s >= w * 1.5) sc.scrollLeft -= w;
        if (dir < 0 && sc.scrollLeft - s <= w * 0.5) sc.scrollLeft += w;
        sc.scrollBy({ left: dir * s, behavior: "smooth" });
      };
      const prev = document.getElementById("psPrev");
      const next = document.getElementById("psNext");
      if (prev) prev.addEventListener("click", () => go(-1));
      if (next) next.addEventListener("click", () => go(1));
    })();

    // live GitHub contributions (only present when the section is shown)
    (async function () {
      const grid = document.getElementById("ghGrid");
      if (!grid) return;
      const note = document.getElementById("ghNote");
      const user = "ShreyNiraula";
      const colors = ["#13203a", "#0e5a4a", "#1c8f6f", "#28c98f", "#34e0a1"];
      const setText = (id, v) => {
        const el = document.getElementById(id);
        if (el) el.textContent = v;
      };
      try {
        const res = await fetch(
          "https://github-contributions-api.jogruber.de/v4/" + user + "?y=last",
        );
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json();
        const days = data.contributions || [];
        if (!days.length) throw new Error("no contribution data");
        grid.innerHTML = "";
        const pad = new Date(days[0].date + "T00:00:00").getDay();
        for (let i = 0; i < pad; i++) {
          const c = document.createElement("div");
          c.className = "gh-cell pad";
          grid.appendChild(c);
        }
        let total = 0,
          bestDay = 0,
          run = 0,
          longest = 0;
        days.forEach((d) => {
          const cell = document.createElement("div");
          cell.className = "gh-cell";
          cell.style.background = colors[d.level] || colors[0];
          cell.title =
            d.count +
            " contribution" +
            (d.count === 1 ? "" : "s") +
            " on " +
            d.date;
          grid.appendChild(cell);
          total += d.count;
          bestDay = Math.max(bestDay, d.count);
          run = d.count > 0 ? run + 1 : 0;
          longest = Math.max(longest, run);
        });
        setText("ghTotal", total.toLocaleString());
        setText("ghStreak", longest + (longest === 1 ? " day" : " days"));
        setText("ghBest", String(bestDay));
        if (note) note.remove();
      } catch (e) {
        if (note)
          note.textContent =
            "// Live GitHub contributions are unavailable right now. Try refreshing.";
      }
    })();

    // contact form opens a prefilled email
    const form = document.getElementById("contactForm");
    if (form) {
      form.addEventListener("submit", (ev) => {
        ev.preventDefault();
        const name = document.getElementById("cfName").value || "";
        const email = document.getElementById("cfEmail").value || "";
        const msg = document.getElementById("cfMsg").value || "";
        const body = encodeURIComponent(
          msg + "\n\n-- " + name + " (" + email + ")",
        );
        const subject = encodeURIComponent("Portfolio inquiry from " + name);
        window.location.href =
          "mailto:nshrey53@gmail.com?subject=" + subject + "&body=" + body;
      });
    }

    // experience: click to expand/collapse bullets (smooth, measured height)
    document.querySelectorAll(".tl-toggle").forEach((btn) => {
      const item = btn.closest(".tl-item");
      if (!item) return;
      const region = item.querySelector(".tl-collapse");
      btn.addEventListener("click", () => {
        const open = item.classList.toggle("open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
        if (region)
          region.style.maxHeight = open ? region.scrollHeight + "px" : "40px";
      });
    });
  </script>
</SiteLayout>
