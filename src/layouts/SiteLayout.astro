---
// Shared chrome for the Shrey Niraula design system (v2 navy direction).
type Props = { title: string; description: string; path?: string };
const { title, description, path = "/" } = Astro.props;

const resume = "/Shrey_Niraula_AI_ML_Resume.pdf";
const social = {
  email: "mailto:nshrey53@gmail.com",
  github: "https://github.com/ShreyNiraula",
  linkedin: "https://www.linkedin.com/in/shrey-niraula-27947b189/",
  website: "https://shreyniraula.com.np"
};
const canonical = Astro.site ? new URL(path, Astro.site).toString() : path;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0b0e" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Shrey Niraula" />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;600;800;900&family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("theme") === "light")
            document.documentElement.setAttribute("data-theme", "light");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header>
      <div class="wrap nav">
        <a class="mark" href="/">SHREY NIRAULA<b>.</b></a>
        <div class="nav-mid">
          <nav class="nav-links">
            <a href="/#about">ABOUT</a>
            <a href="/#skills">SKILLS</a>
            <a href="/#xp">EXPERIENCE</a>
            <a href="/#education">EDUCATION</a>
            <a href="/#projects">PROJECTS</a>
            <a href="/#contact">CONTACTS</a>
          </nav>
          <a class="nav-cta" href={resume} target="_blank" rel="noopener">RESUME</a>
        </div>
        <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle light and dark mode">
          <i class="fa-solid fa-moon"></i>
          <i class="fa-solid fa-sun"></i>
          <span class="tt-knob"></span>
        </button>
      </div>
    </header>

    <slot />

    <footer>
      <div class="wrap">
        <span>© 2026 Shrey Niraula · Data Engineer</span>
        <span class="foot-links">
          <a href={social.github} target="_blank" rel="noopener">GitHub</a>
          <a href={social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={resume} target="_blank" rel="noopener">Resume</a>
        </span>
      </div>
    </footer>

    <div class="social-rail">
      <a href={social.github} target="_blank" rel="noopener" title="GitHub"><i class="fa-brands fa-github"></i></a>
      <a href={social.linkedin} target="_blank" rel="noopener" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
      <a href={social.email} title="Email"><i class="fa-solid fa-envelope"></i></a>
      <a href={social.website} target="_blank" rel="noopener" title="Website"><i class="fa-solid fa-globe"></i></a>
      <a href={resume} target="_blank" rel="noopener" title="Resume"><i class="fa-solid fa-id-badge"></i></a>
      <div class="line"></div>
    </div>

    <div class="scroll-rail" aria-hidden="true"><div class="scroll-fill" id="scrollFill"></div></div>

    <style is:global>
      :root {
        --bg: #0a0b0e;
        --card: #14161c;
        --card-2: #1a1c23;
        --line: rgba(255, 255, 255, 0.09);
        --line-2: rgba(255, 255, 255, 0.16);
        --ink: #f5f7ff;
        --ink-2: #a7b2cc;
        --ink-3: #6b7799;
        --acc: #22d3ee;
        --acc-ink: #04141a;
        --sky: #6dbafd;
        --green: #34e0a1;
        --header-bg: rgba(10, 11, 14, 0.78);
        --font-disp: "Archivo", system-ui, sans-serif;
        --font-ui: "Space Grotesk", system-ui, sans-serif;
        --font-mono: "IBM Plex Mono", monospace;
      }
      :root[data-theme="light"] {
        --bg: #f4f6fb;
        --card: #ffffff;
        --card-2: #eef1f7;
        --line: rgba(12, 22, 42, 0.16);
        --line-2: rgba(12, 22, 42, 0.26);
        --ink: #0e1320;
        --ink-2: #3c465c;
        --ink-3: #545e70;
        --acc: #0c93b3;
        --acc-ink: #ffffff;
        --sky: #2570cf;
        --green: #0f9b6a;
        --header-bg: rgba(244, 246, 251, 0.82);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg); color: var(--ink); font-family: var(--font-ui);
        -webkit-font-smoothing: antialiased; overflow-x: hidden;
        background-image:
          radial-gradient(circle at 12% 6%, rgba(34, 211, 238, 0.04), transparent 40%),
          radial-gradient(circle at 90% 2%, rgba(59, 130, 246, 0.04), transparent 42%);
        background-attachment: fixed;
      }
      ::selection { background: var(--acc); color: var(--acc-ink); }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
      .kick { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--acc); display: inline-flex; gap: 8px; align-items: center; }
      .kick .slash { color: var(--ink-3); }

      header { position: sticky; top: 0; z-index: 60; backdrop-filter: blur(12px); background: var(--header-bg); border-bottom: 1px solid var(--line); }
      .nav { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .mark { font-family: var(--font-disp); font-weight: 900; font-size: 20px; letter-spacing: -0.02em; }
      .mark b { color: var(--acc); }
      .nav-links { display: flex; gap: 24px; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-2); }
      .nav-links a:hover { color: var(--acc); }
      .nav-cta { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; border: none; padding: 10px 20px; border-radius: 999px; background: var(--acc); color: var(--acc-ink); font-weight: 600; transition: 0.18s; }
      .nav-mid { display: flex; align-items: center; gap: 26px; }
      .theme-toggle { position: relative; width: 52px; height: 26px; flex: none; border-radius: 999px; border: 1px solid var(--line-2); background: var(--card-2); cursor: pointer; display: flex; align-items: center; justify-content: space-between; padding: 0 7px; transition: border-color 0.18s; }
      .theme-toggle:hover { border-color: var(--acc); }
      .theme-toggle i { font-size: 10px; line-height: 1; }
      .theme-toggle .fa-moon { color: var(--sky); }
      .theme-toggle .fa-sun { color: #e6b53d; }
      .tt-knob { position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; border-radius: 50%; background: var(--ink); transition: left 0.22s cubic-bezier(0.22, 1, 0.36, 1); }
      :root[data-theme="light"] .tt-knob { left: 30px; }
      .nav-cta:hover { filter: brightness(1.06); box-shadow: 0 6px 18px rgba(34, 211, 238, 0.35); }
      @media (max-width: 900px) { .nav-links { display: none; } }

      .hero { padding: 96px 0 70px; position: relative; }
      .greet-line { display: flex; align-items: center; gap: 5px; min-height: 1.25em; margin-bottom: 22px; font-family: var(--font-disp); font-weight: 800; font-style: italic; font-size: clamp(26px, 3.4vw, 38px); letter-spacing: -0.01em; line-height: 1.1; color: var(--acc); }
      .caret { width: 3px; height: 1.05em; background: var(--acc); display: inline-block; border-radius: 1px; animation: caretBlink 1s steps(1) infinite; }
      @keyframes caretBlink { 50% { opacity: 0; } }
      .status { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); margin-bottom: 26px; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--acc); animation: pulse 2.2s infinite; }
      @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34, 211, 238, 0.5); } 70% { box-shadow: 0 0 0 9px rgba(34, 211, 238, 0); } 100% { box-shadow: 0 0 0 0 rgba(34, 211, 238, 0); } }
      h1.big { font-family: var(--font-disp); font-weight: 900; line-height: 0.86; letter-spacing: -0.03em; font-size: clamp(60px, 13vw, 184px); text-transform: uppercase; }
      h1.big .ghost { color: transparent; -webkit-text-stroke: 1.5px var(--ink-3); }
      h1.big .fill { color: var(--ink); }
      .hero .lede { margin-top: 28px; max-width: 52ch; font-size: 18.5px; line-height: 1.65; color: var(--ink-2); }
      .hero .lede b { color: var(--acc); font-weight: 500; }
      .cta-row { display: flex; gap: 14px; margin-top: 30px; flex-wrap: wrap; align-items: center; }
      .btn { font-family: var(--font-mono); font-size: 13px; padding: 13px 26px; border-radius: 999px; border: 1px solid var(--line-2); display: inline-flex; align-items: center; gap: 9px; cursor: pointer; transition: 0.18s; }
      .btn.primary { background: var(--acc); color: var(--acc-ink); border: none; border-radius: 999px; font-weight: 600; padding: 14px 32px; }
      .btn.primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(34, 211, 238, 0.4); filter: brightness(1.06); }
      .btn.ghost:hover { border-color: var(--acc); color: var(--acc); }
      .hero-stats { display: flex; gap: 46px; margin-top: 56px; border-top: 1px solid var(--line); padding-top: 28px; flex-wrap: wrap; }
      .stat .n { font-family: var(--font-disp); font-weight: 800; font-size: 38px; color: var(--acc); line-height: 1; letter-spacing: -0.02em; }
      .stat .l { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 8px; }

      section.band { padding: 88px 0; border-top: 1px solid var(--line); }
      .sec-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 44px; gap: 24px; flex-wrap: wrap; }
      .sec-head h2 { font-family: var(--font-disp); font-weight: 900; font-size: clamp(32px, 4.4vw, 56px); letter-spacing: -0.02em; text-transform: uppercase; }

      .page-head { padding: 80px 0 16px; }
      .page-head h1 { font-family: var(--font-disp); font-weight: 900; font-size: clamp(48px, 9vw, 120px); letter-spacing: -0.03em; text-transform: uppercase; line-height: 0.9; margin-top: 18px; }
      .page-head .lede { margin-top: 22px; max-width: 60ch; font-size: 17px; line-height: 1.7; color: var(--ink-2); }

      .about { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 50px; align-items: center; }
      .about .pic { position: relative; display: flex; justify-content: center; }
      .about .pic img {
        width: clamp(260px, 30vw, 360px); aspect-ratio: 1; border-radius: 50%;
        object-fit: cover; object-position: 50% 0%;
        background: transparent;
      }
      .about-greet { font-size: clamp(22px, 2.6vw, 30px); margin-bottom: 16px; }
      .about p { font-size: 18px; line-height: 1.78; color: var(--ink-2); margin-bottom: 16px; }
      .about p b { color: var(--ink); font-weight: 600; }
      .about .langs { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
      .lang { font-family: var(--font-mono); font-size: 12px; color: var(--sky); border: 1px solid rgba(109, 186, 253, 0.3); background: rgba(109, 186, 253, 0.07); border-radius: 999px; padding: 6px 12px; }

      /* projects: horizontal scroll row (3 visible) */
      .pscroll { display: flex; gap: 22px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 4px 2px 26px; scrollbar-width: none; }
      .pscroll::-webkit-scrollbar { display: none; }
      .pcf-card { scroll-snap-align: start; flex: 0 0 calc((100% - 44px) / 3); min-width: 0; display: flex; flex-direction: column; overflow: hidden; background: var(--card); border: 1px solid var(--line); border-radius: 16px; transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s; }
      .pcf-card:hover { transform: translateY(-4px); border-color: var(--acc); box-shadow: 0 18px 40px rgba(0, 0, 0, 0.4); }
      .pcf-card.no-media .ps-body { justify-content: center; }
      .ps-media { position: relative; width: 100%; height: 175px; flex: none; overflow: hidden; background: var(--card-2); }
      .ps-media img { width: 100%; height: 100%; object-fit: cover; }
      .ps-media::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8, 9, 12, 0) 55%, rgba(8, 9, 12, 0.6)); }
      .ps-body { flex: 1; padding: 18px 20px; display: flex; flex-direction: column; gap: 13px; min-width: 0; }
      .ps-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .ps-count { font-family: var(--font-disp); font-weight: 900; font-size: 22px; color: var(--ink-3); letter-spacing: -0.02em; line-height: 1; }
      .ps-count b { color: var(--acc); }
      .ps-top { display: flex; align-items: center; gap: 10px; }
      .ps-top .badge { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--acc); border: 1px solid var(--acc); border-radius: 999px; padding: 2px 9px; }
      .ps-yr { font-family: var(--font-mono); font-size: 12px; color: var(--sky); }
      .pcf-card h3 { font-family: var(--font-disp); font-weight: 800; font-size: 19px; line-height: 1.16; letter-spacing: -0.01em; }
      .ps-body p { font-size: 14px; line-height: 1.55; color: var(--ink-2); }
      .ps-stack { display: flex; flex-wrap: wrap; gap: 6px; }
      .ps-stack span { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 999px; padding: 3px 9px; }
      .ps-links { display: flex; gap: 9px; flex-wrap: wrap; margin-top: auto; }
      .ps-link { font-family: var(--font-mono); font-size: 11px; color: var(--ink); border: 1px solid var(--line-2); border-radius: 999px; padding: 7px 12px; display: inline-flex; align-items: center; gap: 7px; transition: 0.18s; }
      .ps-link:hover { border-color: var(--acc); color: var(--acc); transform: translateY(-2px); }
      .pshow-nav { display: flex; gap: 12px; align-items: center; justify-content: center; margin-top: 24px; }
      .ps-nav-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--line-2); background: var(--card); color: var(--ink); font-size: 16px; cursor: pointer; transition: 0.18s; }
      .ps-nav-btn:hover { border-color: var(--acc); color: var(--acc); transform: translateY(-2px); }

      /* project grid (projects page) */
      .proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
      .proj-card { background: var(--card); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; transition: 0.22s; }
      .proj-card:hover { transform: translateY(-4px); border-color: var(--acc); box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45); }
      .proj-card .thumb { aspect-ratio: 16 / 10; background: var(--card-2); position: relative; overflow: hidden; }
      .proj-card .thumb img { width: 100%; height: 100%; object-fit: cover; transition: 0.3s; }
      .proj-card:hover .thumb img { transform: scale(1.05); }
      .proj-card .thumb::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8, 9, 12, 0) 55%, rgba(8, 9, 12, 0.55)); }
      .proj-card .thumb.noimg { display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #14161c, #20242e); }
      .proj-card .thumb.noimg::after { display: none; }
      .proj-card .thumb.noimg span { font-family: var(--font-mono); color: var(--acc); letter-spacing: 0.1em; font-size: 14px; }
      .proj-card .pc-body { padding: 18px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
      .proj-card .pc-top { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
      .proj-card .pc-yr { font-family: var(--font-mono); font-size: 11px; color: var(--sky); text-transform: uppercase; letter-spacing: 0.06em; }
      .proj-card .badge { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--acc); border: 1px solid var(--acc); border-radius: 999px; padding: 2px 8px; }
      .proj-card h3 { font-family: var(--font-disp); font-weight: 800; font-size: 19px; line-height: 1.18; letter-spacing: -0.01em; }
      .proj-card p { font-size: 14px; line-height: 1.55; color: var(--ink-2); }
      .proj-card .pc-stack { display: flex; flex-wrap: wrap; gap: 7px; margin-top: auto; padding-top: 4px; }
      .proj-card .pc-stack span { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 4px; padding: 4px 8px; }
      .proj-card .pc-links { display: flex; gap: 16px; padding: 0 18px 18px; }
      .proj-card .pc-links a { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); display: inline-flex; gap: 6px; align-items: center; transition: 0.15s; }
      .proj-card .pc-links a:hover { color: var(--acc); }

      .more-wrap { display: flex; justify-content: center; margin-top: 34px; }
      .more-btn { font-family: var(--font-disp); font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em; font-size: 15px; color: var(--ink); border: 1px solid var(--line-2); border-radius: 999px; padding: 13px 28px; display: inline-flex; align-items: center; gap: 12px; transition: 0.2s; }
      .more-btn:hover { border-color: var(--acc); color: var(--acc); transform: translateY(-2px); }
      .more-btn .a { color: var(--acc); }

      /* skills - embedded layout (no cards) */
      .stack-list { display: flex; flex-direction: column; }
      .stack-row { display: grid; grid-template-columns: 220px 1fr; gap: 30px; align-items: start; position: relative; padding: 30px 0; }
      .stack-row:first-child { padding-top: 4px; }
      .stack-row:not(:first-child)::after { content: ""; position: absolute; left: 0; right: 0; top: 0; height: 1px; background: linear-gradient(90deg, var(--line-2), transparent 75%); }
      .stack-cat { font-family: var(--font-disp); font-weight: 800; font-size: clamp(18px, 1.8vw, 24px); text-transform: uppercase; letter-spacing: -0.01em; line-height: 1.15; color: var(--ink-3); }
      .stack-items { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px 18px; }
      .sk { display: flex; align-items: center; gap: 13px; transition: transform 0.18s; }
      .sk:hover { transform: translateX(3px); }
      .sk-logo { width: 36px; height: 36px; object-fit: contain; flex: none; }
      .sk i { font-size: 34px; width: 36px; text-align: center; }
      .sk-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--acc); flex: none; margin: 0 13px; }
      .sk-name { font-size: 16px; color: var(--ink-2); transition: color 0.18s; }
      .sk:hover .sk-name { color: var(--ink); }
      .sk .on-white { background: #fff; border-radius: 8px; padding: 4px; box-sizing: border-box; }
      .sk i.on-white { width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; font-size: 26px; padding: 3px; }
      /* skills entrance animation (staggered) */
      .stack-cat, .stack-row .sk { opacity: 0; transform: translateY(14px); transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
      .stack-row.in .stack-cat, .stack-row.in .sk { opacity: 1; transform: none; }
      .stack-row.in .sk:nth-child(1) { transition-delay: 0.05s; }
      .stack-row.in .sk:nth-child(2) { transition-delay: 0.1s; }
      .stack-row.in .sk:nth-child(3) { transition-delay: 0.15s; }
      .stack-row.in .sk:nth-child(4) { transition-delay: 0.2s; }
      .stack-row.in .sk:nth-child(5) { transition-delay: 0.25s; }
      .stack-row.in .sk:nth-child(6) { transition-delay: 0.3s; }
      .stack-row.in .sk:nth-child(7) { transition-delay: 0.35s; }
      .stack-row.in .sk:nth-child(8) { transition-delay: 0.4s; }

      .tl { position: relative; max-width: 820px; margin: 0; }
      .tl::before { content: ""; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 2px; background: var(--line); }
      .tl-item { position: relative; width: 100%; padding: 0 0 40px 36px; }
      .tl-item::before { content: ""; position: absolute; top: 6px; left: -1px; width: 16px; height: 16px; border-radius: 50%; background: var(--acc); box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.16); z-index: 2; }
      .tl-card { background: none; border: none; padding: 0; }
      .tl-when { font-family: var(--font-mono); font-size: 13px; color: var(--sky); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
      .tl-when .badge { margin-left: auto; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--acc); border: 1px solid var(--acc); border-radius: 999px; padding: 1px 8px; }
      .tl-headrow { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
      .tl-card h3 { font-family: var(--font-disp); font-weight: 800; font-size: 23px; letter-spacing: -0.01em; }
      .tl-loc { font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-3); white-space: nowrap; display: inline-flex; align-items: center; gap: 5px; }
      .tl-loc i { color: var(--sky); }
      .tl-card .co { font-family: var(--font-mono); font-size: 14px; color: var(--acc); margin: 7px 0 14px; }
      .tl-card ul { list-style: none; display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px; }
      .tl-card li { font-size: 15.5px; line-height: 1.55; color: var(--ink-2); padding-left: 16px; position: relative; }
      .tl-card li::before { content: "\25B8"; position: absolute; left: 0; color: var(--ink-3); }
      .tl-card .stack { display: flex; flex-wrap: wrap; gap: 6px; }
      .tl-card .stack span { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 4px; padding: 4px 8px; }
      .tl-collapse { overflow: hidden; max-height: 40px; transition: max-height 0.55s cubic-bezier(0.22, 1, 0.36, 1); }
      .tl-item:not(.open) .tl-collapse { -webkit-mask-image: linear-gradient(180deg, #000 24%, transparent); mask-image: linear-gradient(180deg, #000 24%, transparent); }
      .tl-toggle { background: none; border: none; padding: 0; margin-top: 2px; color: var(--ink-3); font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: color 0.15s; }
      .tl-toggle:hover { color: var(--acc); }
      .tl-toggle i { transition: transform 0.3s; }
      .tl-item.open .tl-toggle i { transform: rotate(180deg); }
      .tl-toggle .less-label { display: none; }
      .tl-item.open .tl-toggle .more-label { display: none; }
      .tl-item.open .tl-toggle .less-label { display: inline; }

      /* participations */
      .parts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .part { background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 18px; display: flex; flex-direction: column; gap: 8px; transition: 0.2s; }
      .part:hover { border-color: var(--acc); transform: translateY(-4px); box-shadow: 0 18px 40px rgba(0, 0, 0, 0.4); }
      .parts.embed { gap: 26px 28px; }
      .parts.embed .part { background: none; border: none; border-left: 2px solid var(--line); border-radius: 0; padding: 4px 0 4px 18px; }
      .parts.embed .part:hover { transform: none; box-shadow: none; border-left-color: var(--acc); }
      .part-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
      .part-top .badge { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--acc); border: 1px solid var(--acc); border-radius: 999px; padding: 2px 9px; }
      .part-yr { font-family: var(--font-mono); font-size: 12px; color: var(--sky); }
      .part h3 { font-family: var(--font-disp); font-weight: 800; font-size: 17px; line-height: 1.2; letter-spacing: -0.01em; }
      .part-ev { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); }
      .part-desc { font-size: 13.5px; line-height: 1.55; color: var(--ink-2); }
      .part-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; padding-top: 4px; }
      .part-tags span { font-family: var(--font-mono); font-size: 10px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 4px; padding: 3px 7px; }

      /* education - clean editorial rows */
      .edu-clean { display: flex; flex-direction: column; }
      .edu-row { display: grid; grid-template-columns: 175px 1fr; gap: 30px; padding: 30px 0; border-top: 1px solid var(--line); }
      .edu-row:first-child { border-top: none; padding-top: 4px; }
      .edu-side { padding-top: 6px; }
      .edu-side .edu-score { font-family: var(--font-mono); font-size: 13px; color: var(--green); line-height: 1.5; }
      .edu-headrow { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; flex-wrap: wrap; }
      .edu-main h3 { font-family: var(--font-disp); font-weight: 800; font-size: 22px; letter-spacing: -0.01em; }
      .edu-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; font-family: var(--font-mono); font-size: 12.5px; white-space: nowrap; }
      .edu-meta .edu-when { color: var(--sky); }
      .edu-meta .edu-loc { color: var(--ink-3); display: inline-flex; gap: 5px; align-items: center; }
      .edu-meta .edu-loc i { color: var(--sky); }
      .edu-deg { font-family: var(--font-mono); font-size: 13px; font-style: italic; color: var(--acc); margin-top: 6px; }
      .edu-hl { font-size: 14.5px; line-height: 1.6; color: var(--ink-2); margin: 14px 0; }
      .edu-subjects { display: flex; flex-wrap: wrap; gap: 7px; }
      .edu-subjects span { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 4px; padding: 4px 9px; }
      @media (max-width: 720px) { .edu-row { grid-template-columns: 1fr; gap: 10px; } .edu-meta { align-items: flex-start; } }

      /* certifications */
      .cert-courses { display: flex; flex-direction: column; gap: 5px; margin-top: 2px; }
      .cert-courses a, .cert-courses span { font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-3); padding-left: 14px; position: relative; line-height: 1.4; }
      .cert-courses a::before, .cert-courses span::before { content: "\25B8"; position: absolute; left: 0; color: var(--ink-3); }
      .cert-courses a:hover { color: var(--acc); }
      .cert-verify { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--sky); display: inline-flex; align-items: center; gap: 6px; margin-top: auto; padding-top: 4px; }
      .cert-verify:hover { color: var(--acc); }

      /* project detail */
      .detail .wrap { max-width: 900px; }
      .d-back { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); display: inline-flex; align-items: center; gap: 7px; transition: 0.15s; }
      .d-back:hover { color: var(--acc); }
      .detail .d-title { font-family: var(--font-disp); font-weight: 900; font-size: clamp(28px, 4.4vw, 46px); letter-spacing: -0.02em; line-height: 1.08; text-transform: uppercase; margin: 16px 0 0; }
      .d-meta { display: flex; flex-wrap: wrap; gap: 10px 16px; align-items: center; margin-top: 14px; font-family: var(--font-mono); font-size: 12px; }
      .d-meta .sub { color: var(--ink-2); }
      .d-meta .yr { color: var(--sky); }
      .d-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; }
      .d-links a { font-family: var(--font-mono); font-size: 12px; color: var(--ink); border: 1px solid var(--line-2); border-radius: 999px; padding: 9px 16px; display: inline-flex; align-items: center; gap: 8px; transition: 0.18s; }
      .d-links a:hover { border-color: var(--acc); color: var(--acc); transform: translateY(-2px); }
      .d-stack { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 20px; }
      .d-stack span { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); border: 1px solid var(--line); border-radius: 4px; padding: 4px 9px; }
      .d-lead { font-size: 18px; line-height: 1.7; color: var(--ink); margin-bottom: 30px; }
      .d-hero { border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-bottom: 30px; background: var(--card-2); }
      .d-hero img { width: 100%; height: auto; display: block; }
      .d-video { aspect-ratio: 16 / 9; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-bottom: 30px; background: #000; }
      .d-video iframe { width: 100%; height: 100%; border: 0; display: block; }
      .d-block { margin-bottom: 34px; }
      .d-block h4 { font-family: var(--font-disp); font-weight: 800; font-size: 22px; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 16px; display: inline-flex; align-items: baseline; gap: 10px; }
      .d-block h4 .slash { font-family: var(--font-mono); font-size: 13px; color: var(--acc); }
      .d-block p { font-size: 15.5px; line-height: 1.75; color: var(--ink-2); }
      .d-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
      .d-gallery .shot { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--card-2); }
      .d-gallery .shot:last-child:nth-child(odd) { grid-column: 1 / -1; }
      .d-gallery .shot img { width: 100%; height: auto; object-fit: contain; display: block; }
      .d-feature { border-left: 2px solid var(--acc); padding-left: 18px; margin-bottom: 22px; }
      .d-feature strong { font-family: var(--font-disp); font-weight: 800; font-size: 16px; color: var(--ink); display: block; margin-bottom: 8px; }
      .d-feature p { font-size: 14.5px; line-height: 1.65; color: var(--ink-2); }
      .d-feature .images { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 14px; }
      .d-feature .images img { width: 100%; max-width: 480px; border: 1px solid var(--line); border-radius: 10px; }
      .d-team { display: flex; flex-wrap: wrap; gap: 16px; }
      .d-team img { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 1px solid var(--line-2); transition: 0.18s; }
      .d-team a:hover img { border-color: var(--acc); transform: translateY(-2px); }
      .d-nav { display: flex; justify-content: space-between; gap: 16px; border-top: 1px solid var(--line); padding-top: 26px; margin-top: 10px; font-family: var(--font-mono); font-size: 13px; }
      .d-nav a { display: inline-flex; align-items: center; gap: 8px; color: var(--ink-2); transition: 0.15s; }
      .d-nav a:hover { color: var(--acc); }
      @media (max-width: 720px) { .d-gallery { grid-template-columns: 1fr; } }

      .gh-wrap { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 26px; }
      .gh-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
      .gh-top .t { font-family: var(--font-mono); font-size: 13px; color: var(--ink-2); letter-spacing: 0.06em; text-transform: uppercase; display: flex; align-items: center; gap: 9px; }
      .gh-top .t .live { width: 7px; height: 7px; border-radius: 50%; background: var(--green); }
      .gh-top .h { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); }
      .gh-top .h:hover { color: var(--green); }
      .gh-grid { display: grid; grid-template-rows: repeat(7, 1fr); grid-auto-flow: column; grid-auto-columns: 1fr; gap: 3px; overflow-x: auto; padding-bottom: 6px; }
      .gh-cell { width: 100%; aspect-ratio: 1; min-width: 9px; border-radius: 2px; background: #13203a; }
      .gh-cell.pad { background: transparent; }
      .gh-legend { display: flex; align-items: center; gap: 7px; justify-content: flex-end; margin-top: 14px; font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); }
      .gh-legend .sw { width: 11px; height: 11px; border-radius: 2px; }
      .gh-stats { display: flex; gap: 34px; margin-top: 22px; flex-wrap: wrap; }
      .gh-stats .s .n { font-family: var(--font-disp); font-weight: 800; font-size: 26px; color: var(--green); line-height: 1; }
      .gh-stats .s .l { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 6px; }
      .gh-note { font-family: var(--font-mono); font-size: 10px; color: var(--ink-3); margin-top: 16px; line-height: 1.5; }

      .contact { display: grid; grid-template-columns: 1fr 1fr; gap: 46px; align-items: stretch; }
      .find a { display: flex; align-items: center; gap: 14px; border: 1px solid var(--line); border-radius: 8px; padding: 15px 17px; margin-bottom: 11px; font-family: var(--font-mono); font-size: 15px; transition: 0.18s; }
      .find a:last-child { margin-bottom: 0; }
      .find a:hover { border-color: var(--acc); background: var(--card); transform: translateX(5px); }
      .find a:hover .ic i { color: var(--acc); }
      .find a .ic { width: 26px; text-align: center; }
      .find a .ic i { font-size: 18px; color: var(--ink-2); transition: 0.18s; }
      .find a .plat { color: var(--ink); font-weight: 500; width: 96px; }
      .find a .hand { color: var(--ink-3); margin-left: auto; }
      .form label { display: block; font-family: var(--font-mono); font-size: 13px; color: var(--ink-3); margin: 0 0 7px; text-transform: uppercase; letter-spacing: 0.06em; }
      .form .star { color: var(--acc); }
      .form { display: flex; flex-direction: column; height: 100%; }
      .form .field { margin-bottom: 12px; }
      .form input, .form textarea { width: 100%; background: var(--card); border: 1px solid var(--line); border-radius: 6px; color: var(--ink); font-family: var(--font-mono); font-size: 15px; padding: 10px 14px; outline: none; transition: 0.18s; }
      .form textarea { height: 50px; resize: vertical; }
      .form .btn { align-self: flex-start; margin-top: auto; }
      .form input:focus, .form textarea:focus { border-color: var(--acc); }

      footer { border-top: 1px solid var(--line); padding: 32px 0; margin-top: 40px; }
      footer .wrap { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); }
      .foot-links { display: flex; gap: 20px; }
      .foot-links a:hover { color: var(--acc); }

      .social-rail { position: fixed; left: 26px; bottom: 0; z-index: 55; display: flex; flex-direction: column; align-items: center; gap: 18px; color: var(--ink-2); }
      .social-rail a { font-size: 17px; transition: 0.18s; opacity: 0.85; }
      .social-rail a:hover { transform: translateY(-2px); opacity: 1; color: var(--acc); }
      .social-rail .line { width: 1px; height: 80px; background: currentColor; opacity: 0.4; }
      @media (max-width: 1100px) { .social-rail { display: none; } }

      .scroll-rail { position: fixed; right: 22px; top: 50%; transform: translateY(-50%); width: 3px; height: 160px; background: var(--line-2); border-radius: 999px; z-index: 55; overflow: hidden; }
      .scroll-fill { position: absolute; top: 0; left: 0; width: 100%; height: 0; background: var(--ink); border-radius: 999px; }
      @media (max-width: 1100px) { .scroll-rail { display: none; } }

      .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1); }
      .reveal.in { opacity: 1; transform: none; }
      @media (max-width: 1000px) { .pcf-card { flex-basis: calc((100% - 22px) / 2); } }
      @media (max-width: 860px) {
        .about { grid-template-columns: 1fr; }
        .contact { grid-template-columns: 1fr; }
        .parts { grid-template-columns: 1fr; }
        .proj-grid { grid-template-columns: 1fr; }
        .stack-row { grid-template-columns: 1fr; gap: 14px; }
        .stack-items { grid-template-columns: repeat(2, 1fr); }
        .pcf-card { flex-basis: 86%; }
        .ps-media { height: 170px; }
        .tl::before { left: 7px; }
        .tl-item { width: 100%; left: 0 !important; padding: 0 0 28px 34px; }
        .tl-item::before { left: -1px !important; right: auto !important; }
        .tl-when .badge { margin-left: 8px; }
      }
    </style>

    <script is:inline>
      // scroll-reveal (shared across pages)
      const io = new IntersectionObserver(
        (es) =>
          es.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }),
        { threshold: 0.12 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // scroll progress rail (right side)
      const scrollFill = document.getElementById("scrollFill");
      if (scrollFill) {
        let raf = false;
        const update = () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
          scrollFill.style.height = pct + "%";
          raf = false;
        };
        window.addEventListener(
          "scroll",
          () => {
            if (!raf) {
              raf = true;
              requestAnimationFrame(update);
            }
          },
          { passive: true }
        );
        window.addEventListener("resize", update);
        update();
      }

      // theme toggle (dark <-> light), persisted in localStorage
      (function () {
        const btn = document.getElementById("themeToggle");
        if (!btn) return;
        btn.addEventListener("click", () => {
          const isLight =
            document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            try { localStorage.setItem("theme", "dark"); } catch (e) {}
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            try { localStorage.setItem("theme", "light"); } catch (e) {}
          }
        });
      })();
    </script>
  </body>
</html>
