---
import type { CollectionEntry } from "astro:content";

type Props = {
  item: CollectionEntry<"participations">;
};

const { item } = Astro.props;
---

<article class="legacy-card h-100">
  <div class="legacy-time-row">
    <p>{item.data.year}</p>
    {item.data.badgeLabel && <span class="legacy-current-pill">{item.data.badgeLabel}</span>}
  </div>

  <div class="legacy-card-content">
    <h3>{item.data.title}</h3>
    <p class="legacy-company">
      {item.data.event} · {item.data.location}
    </p>
    <p class="legacy-card-details">{item.data.description}</p>
  </div>

  <div class="legacy-tags legacy-tags-fixed">
    {
      item.data.tags.map((tag) => (
        <span>{tag}</span>
      ))
    }
  </div>
</article>